# ──────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ──────────────────────────────────────────────
# Environment & Secrets  ← NEVER commit these
# ──────────────────────────────────────────────
.env
.env.*
!.env.example        # keep the template

# ──────────────────────────────────────────────
# Build output
# ──────────────────────────────────────────────
dist/
build/
out/

# ──────────────────────────────────────────────
# Vite / frontend tooling
# ──────────────────────────────────────────────
frontend/dist/
frontend/.vite/
*.local

# ──────────────────────────────────────────────
# Uploaded files (encrypted blobs)
# ──────────────────────────────────────────────
backend/uploads/
uploads/

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ──────────────────────────────────────────────
# TypeScript build cache
# ──────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ──────────────────────────────────────────────
# Test / coverage output
# ──────────────────────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────────────────────
# OS generated files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# Editor / IDE
# ──────────────────────────────────────────────
.idea/
*.swp
*.swo

# Keep .vscode/settings.json (project-level rules)
# but ignore personal/machine-specific files
.vscode/extensions.json
.vscode/*.code-workspace

# ──────────────────────────────────────────────
# Misc scratch files
# ──────────────────────────────────────────────
test_upload.txt
*.local.json
